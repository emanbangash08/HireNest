# Root .gitignore

# Ignore node_modules in all workspaces
**/node_modules

# Ignore .env files in all workspaces
**/.env

# Ignore build artifacts
**/dist
**/build

# OS-specific files
.DS_Store
Thumbs.db

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
server/temp_pdfs
server/temp_uploads

# Ignore influence directory
influence/

# Ignore GitHub specific files
.github

mcp-install/brave.json
.cursor/mcp.json
.claude/
.claude/worktrees/

# GSD
.gsd/

# Local Netlify folder
.netlify

# Electron release artifacts
electron/release/
