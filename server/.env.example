PORT=5001
MONGODB_URI=mongodb://localhost:27017/vibehired
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=1d
FRONTEND_URL=http://localhost:5173
ENCRYPTION_KEY=your_encryption_key_32_chars_min

# ═══════════════════════════════════════════════════════════════════════════════
# AI Provider Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Choose your AI provider. Options:
#   gemini              → Google Gemini (default)
#   openai_compatible   → Any OpenAI-compatible API (OpenAI, DeepSeek, GLM, etc.)
#   deepseek            → Alias for openai_compatible (convenience)
#
# DEFAULT_AI_PROVIDER=gemini

# ─── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── DeepSeek — OpenAI-compatible ──────────────────────────────────────────────
# Get your key: https://platform.deepseek.com
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
#
# Alternative (OpenAI-style env names also work):
# OPENAI_API_KEY=your_deepseek_api_key_here
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-v4-flash

# ─── Generic OpenAI-compatible ────────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# AssemblyAI Configuration
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Apify Configuration
APIFY_API_KEY=your_apify_api_key_here
